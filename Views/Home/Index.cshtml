@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
    ViewData["Title"] = "MatchRight - Home";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />

    <style>
            body {
                background: linear-gradient(135deg, #f5e6d3, #e8d5b7);
                min-height: 100vh;
                font-family: Arial, Helvetica, sans-serif;
            }

            .page-wrapper {
                padding: 40px 15px;
            }

            .dashboard-card {
                max-width: 980px;
                margin: 0 auto;
                background: white;
                border-radius: 16px;
                box-shadow: 0 8px 30px rgba(0,0,0,0.15);
                overflow: hidden;
            }

            .header-side {
                background: linear-gradient(135deg, #1e90ff, #0066cc);
                color: white;
                padding: 30px;
                text-align: center;
            }

            .content-side {
                padding: 30px;
                background-color: #fffdf8;
            }

            .welcome-text {
                font-size: 28px;
                font-weight: bold;
                margin-bottom: 10px;
            }

            .action-links a {
                display: block;
                margin-bottom: 14px;
                padding: 13px;
                background-color: #1e90ff;
                color: white;
                text-align: center;
                border-radius: 10px;
                font-weight: bold;
                text-decoration: none;
            }

                .action-links a:hover {
                    background-color: #0066cc;
                }

            .logout-link {
                margin-top: 20px;
                text-align: center;
            }

                .logout-link a {
                    color: #0066cc;
                    font-weight: bold;
                    text-decoration: none;
                }

                    .logout-link a:hover {
                        text-decoration: underline;
                    }

            .profile-photo {
                width: 120px;
                height: 120px;
                object-fit: cover;
                border-radius: 50%;
                border: 4px solid white;
                margin-top: 15px;
            }

            .dashboard-subtitle {
                margin-top: 5px;
                font-size: 16px;
            }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <div class="dashboard-card">
            <div class="header-side">
                <div style="margin-bottom: 15px;">
                    <img src="~/images/matchright-logo.png"
                         alt="MatchRight Logo"
                         style="max-width:200px; width:100%;" />
                </div>

                @if (ViewData["PhotoURL"] != null && ViewData["PhotoURL"].ToString() != "")
                {
                    <div>
                        <img src="@ViewData["PhotoURL"]" alt="Profile Picture" class="profile-photo" />
                    </div>
                }

                <div class="welcome-text">
                    Welcome, @Context.Session.GetString("FirstName")!
                </div>

                <div class="dashboard-subtitle">Your MatchRight dashboard</div>
            </div>

            <div class="content-side">
                <div class="action-links">
                    @if (ViewData["HasProfile"] != null && (bool)ViewData["HasProfile"] == true)
                    {
                        <a asp-controller="Profile" asp-action="ViewProfile">View Profile</a>
                        <a asp-controller="Profile" asp-action="EditProfile">Edit Profile</a>
                    }
                    else
                    {
                        <a asp-controller="Profile" asp-action="CreateProfile">Create Profile</a>
                    }

                    <a asp-controller="Search" asp-action="Index">Browse Profiles</a>
                    <a asp-controller="Likes" asp-action="Sent">My Likes</a>
                    <a asp-controller="Likes" asp-action="Received">People Who Liked Me</a>
                    <a asp-controller="Matches" asp-action="Index">My Matches</a>
                    <a asp-controller="DateRequests" asp-action="Index">Date Requests</a>
                    <a asp-controller="DatePlans" asp-action="Index">Date Plans</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>