@model Project3_DatingSite.Models.ForgotPasswordViewModel

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
}

<!DOCTYPE html>
<html>
<head>
    <title>Reset Password</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
</head>
<body>
    <div class="container">
        <h1>@ViewData["Title"]</h1>
        <hr />

        <form asp-controller="Account" asp-action="ResetPassword" method="POST">
            <input asp-for="MemberID" type="hidden" />
            <input asp-for="Username" type="hidden" />
            <input asp-for="QuestionID" type="hidden" />
            <input asp-for="QuestionText" type="hidden" />

            <div class="form-group">
                <label>Security Question</label>
                <input value="@Model.QuestionText" class="form-control" readonly />
            </div>

            <div class="form-group">
                <label asp-for="Answer" class="form-label"></label>
                <input asp-for="Answer" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" type="password" class="form-control" />
            </div>

            <div class="form-group">
                <input type="submit" value="Reset Password" class="btn btn-primary" />
            </div>
        </form>

        <div>@ViewData["Message"]</div>

        <br />
        <a asp-controller="Account" asp-action="Login">Back to Login</a>
    </div>
</body>
</html>