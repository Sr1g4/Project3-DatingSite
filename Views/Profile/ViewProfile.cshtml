@model Project3_DatingSite.Models.ProfileViewModel

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = null;
    ViewData["Title"] = "MatchRight - My Profile";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
    <style>
            body {
                background: linear-gradient(135deg, #f5e6d3, #e8d5b7);
                min-height: 100vh;
                font-family: Arial, Helvetica, sans-serif;
            }

            .page-wrapper {
                padding: 30px 15px;
            }

            .profile-card {
                max-width: 1000px;
                margin: 0 auto;
                background: white;
                border-radius: 16px;
                box-shadow: 0 8px 30px rgba(0,0,0,0.15);
                overflow: hidden;
            }

            .header-side {
                background: linear-gradient(135deg, #1e90ff, #0066cc);
                color: white;
                padding: 35px 30px;
                text-align: center;
            }

            .content-side {
                padding: 35px 30px;
                background-color: #fffdf8;
            }

            .profile-photo {
                max-width: 220px;
                width: 100%;
                border-radius: 14px;
                border: 4px solid #eef6ff;
            }

            .section-title {
                color: #0066cc;
                font-weight: bold;
                margin-top: 20px;
                margin-bottom: 10px;
                font-size: 20px;
            }

            .info-row {
                margin-bottom: 10px;
            }

            .btn-main {
                background-color: #1e90ff;
                border-color: #1e90ff;
                color: white;
                border-radius: 10px;
                font-weight: bold;
            }

                .btn-main:hover {
                    background-color: #0066cc;
                    border-color: #0066cc;
                    color: white;
                }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <div class="profile-card">
            <div class="header-side">
                <div style="text-align:center; margin-bottom:20px;">
                    <img src="~/images/matchright-logo.png" alt="MatchRight Logo" style="max-width:200px; width:100%;" />
                </div>
                <h2>@Model.FirstName @Model.LastName</h2>
                <p>@Model.City, @Model.State</p>
            </div>

            <div class="content-side">
                <div class="row">
                    <div class="col-sm-4 text-center">
                        <img src="@Model.PhotoURL" alt="Profile Photo" class="profile-photo" />
                    </div>

                    <div class="col-sm-8">
                        <div class="section-title">About Me</div>
                        <p>@Model.ProfileDescription</p>

                        <div class="section-title">Profile Details</div>

                        <div class="info-row"><strong>Age:</strong> @Model.Age</div>
                        <div class="info-row"><strong>Occupation:</strong> @Model.Occupation</div>
                        <div class="info-row"><strong>Commitment Type:</strong> @Model.CommitmentType</div>
                        <div class="info-row"><strong>Height:</strong> @Model.HeightInches inches</div>
                        <div class="info-row"><strong>Weight:</strong> @Model.WeightLbs lbs</div>
                        <div class="info-row"><strong>Profile Contact Email:</strong> @Model.Email</div>
                        <div class="info-row"><strong>Phone:</strong> @Model.Phone</div>
                        <div class="info-row"><strong>Address:</strong> @Model.Address</div>
                        <div class="info-row"><strong>Contact City:</strong> @Model.ContactCity</div>
                        <div class="info-row"><strong>Contact State:</strong> @Model.ContactState</div>
                        <div class="info-row"><strong>Zip:</strong> @Model.Zip</div>
                        <div class="info-row"><strong>Profile Public:</strong> @(Model.IsProfilePublic ? "Yes" : "No")</div>

                        <div style="margin-top:20px;">
                            <a asp-controller="Profile" asp-action="EditProfile" class="btn btn-main">Edit Profile</a>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-default">Back to Home</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>