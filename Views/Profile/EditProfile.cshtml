@model Project3_DatingSite.Models.ProfileViewModel

@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    ViewData["Title"] = "MatchRight - Edit Profile";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #f5e6d3, #e8d5b7);
            min-height: 100vh;
            font-family: Arial, Helvetica, sans-serif;
        }

        .page-wrapper {
            padding: 30px 15px;
        }

        .page-card {
            background-color: white;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
            overflow: hidden;
            max-width: 1100px;
            margin: 0 auto;
        }

        .brand-side {
            background: linear-gradient(135deg, #1e90ff, #0066cc);
            color: white;
            padding: 40px 30px;
            min-height: 100%;
        }

        .form-side {
            background-color: #fffdf8;
            padding: 40px 30px;
        }

        .form-title {
            font-size: 30px;
            font-weight: bold;
            color: #0066cc;
            margin-bottom: 10px;
        }

        .form-subtitle {
            color: #666;
            margin-bottom: 25px;
        }

        .form-control {
            border-radius: 10px;
            height: 44px;
        }

        textarea.form-control {
            height: auto;
        }

        .btn-main {
            background-color: #1e90ff;
            border-color: #1e90ff;
            color: white;
            width: 100%;
            height: 46px;
            border-radius: 10px;
            font-weight: bold;
        }

        .btn-main:hover {
            background-color: #0066cc;
            border-color: #0066cc;
            color: white;
        }

        .message-box {
            margin-top: 15px;
            padding: 10px 12px;
            border-radius: 8px;
            background-color: #f5e6d3;
            color: #8b5e3c;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <div class="page-card">
            <div class="row" style="margin:0;">
                <div class="col-sm-4 brand-side">
                    <div style="text-align:center; margin-bottom:25px;">
                        <img src="~/images/matchright-logo.png" alt="MatchRight Logo" style="max-width:220px; width:100%;" />
                    </div>

                    <h3>Keep your profile fresh.</h3>
                    <p>
                        Update your details so your profile stays accurate and attractive to potential matches.
                    </p>
                </div>

                <div class="col-sm-8 form-side">
                    <div class="form-title">Edit Profile</div>
                    <div class="form-subtitle">Update your MatchRight profile information.</div>

                    <form asp-controller="Profile" asp-action="EditProfile" method="POST">
                        <input asp-for="MemberID" type="hidden" />

                        <div class="row">
                            <div class="col-sm-6 form-group">
                                <label asp-for="FirstName"></label>
                                <input asp-for="FirstName" class="form-control" />
                            </div>
                            <div class="col-sm-6 form-group">
                                <label asp-for="LastName"></label>
                                <input asp-for="LastName" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-6 form-group">
                                <label asp-for="City"></label>
                                <input asp-for="City" class="form-control" />
                            </div>
                            <div class="col-sm-6 form-group">
                                <label asp-for="State"></label>
                                <input asp-for="State" class="form-control" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="ProfileDescription"></label>
                            <textarea asp-for="ProfileDescription" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="form-group">
                            <label asp-for="PhotoURL"></label>
                            <input asp-for="PhotoURL" class="form-control" />
                        </div>

                        <div class="row">
                            <div class="col-sm-4 form-group">
                                <label asp-for="Age"></label>
                                <input asp-for="Age" class="form-control" />
                            </div>
                            <div class="col-sm-4 form-group">
                                <label asp-for="HeightInches"></label>
                                <input asp-for="HeightInches" class="form-control" />
                            </div>
                            <div class="col-sm-4 form-group">
                                <label asp-for="WeightLbs"></label>
                                <input asp-for="WeightLbs" class="form-control" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Occupation"></label>
                            <input asp-for="Occupation" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label asp-for="CommitmentType"></label>
                            <input asp-for="CommitmentType" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label asp-for="Phone"></label>
                            <input asp-for="Phone" class="form-control" />
                        </div>

                        <div class="form-group">
                            <label asp-for="Address"></label>
                            <input asp-for="Address" class="form-control" />
                        </div>

                        <div class="row">
                            <div class="col-sm-4 form-group">
                                <label asp-for="ContactCity"></label>
                                <input asp-for="ContactCity" class="form-control" />
                            </div>
                            <div class="col-sm-4 form-group">
                                <label asp-for="ContactState"></label>
                                <input asp-for="ContactState" class="form-control" />
                            </div>
                            <div class="col-sm-4 form-group">
                                <label asp-for="Zip"></label>
                                <input asp-for="Zip" class="form-control" />
                            </div>
                        </div>

                        <div class="checkbox">
                            <label>
                                <input asp-for="IsProfilePublic" type="checkbox" />
                                Make my profile public
                            </label>
                        </div>

                        <div class="form-group" style="margin-top:20px;">
                            <input type="submit" value="Save Changes" class="btn btn-main" />
                        </div>
                    </form>

                    @if (ViewData["Message"] != null)
                    {
                        <div class="message-box">
                            @ViewData["Message"]
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</body>
</html>